# Copy to .env.local to run against the local docker-compose stack
# (`docker compose up -d`) with zero cloud accounts needed.

DATABASE_URL="postgresql://eventgallery:eventgallery@localhost:5432/event_gallery"

AUTH_SECRET="local-dev-secret-change-me-0123456789abcdef"

# MinIO, S3-compatible — bucket is created by the setup script below.
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_REGION="us-east-1"
STORAGE_BUCKET="event-gallery-media"
STORAGE_ACCESS_KEY_ID="minioadmin"
STORAGE_SECRET_ACCESS_KEY="minioadmin"
# MinIO serves objects back on the same port; public reads are enabled by
# the setup script so the gallery/slideshow can load media directly.
STORAGE_PUBLIC_BASE_URL="http://localhost:9000/event-gallery-media"
STORAGE_FORCE_PATH_STYLE="true"

CRON_SECRET="local-dev-cron-secret"
APP_BASE_URL="http://localhost:3000"
