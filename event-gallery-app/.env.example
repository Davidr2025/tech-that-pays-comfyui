# Database
DATABASE_URL="postgresql://user:password@localhost:5432/event_gallery"

# Auth
AUTH_SECRET="generate-with-openssl-rand-hex-32"

# Object storage (S3-compatible: Cloudflare R2, AWS S3, etc.)
STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
STORAGE_REGION="auto"
STORAGE_BUCKET="event-gallery-media"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_PUBLIC_BASE_URL="https://media.yourdomain.com"

# Cron protection (Vercel Cron sends this header, or call manually with it)
CRON_SECRET="generate-a-random-string"

# App
APP_BASE_URL="http://localhost:3000"
# Comma-separated hostnames this app itself is served on (not client
# white-label domains) — anything else hitting "/" is treated as a
# potential white-label custom domain. See src/middleware.ts.
APP_HOSTNAMES="localhost:3000,yourapp.vercel.app,yourapp.com"

# Stripe billing (test-mode keys are fine for development)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Recurring Price IDs for the Pro/Agency plans, created in the Stripe dashboard.
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_AGENCY="price_..."

# Google Drive export sync (Agency/Pro plan feature) — from a Google Cloud
# OAuth 2.0 Client ID (Web application), with the Drive API enabled.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
# Must exactly match an authorized redirect URI on the OAuth client:
# {APP_BASE_URL}/api/integrations/google-drive/callback
