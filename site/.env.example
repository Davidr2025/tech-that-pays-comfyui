# ============================================================
# Mississauga Insider — environment variables
# Copy to .env for local use. In production, set these as:
#   - GitHub → repo Settings → Secrets and variables → Actions
#     (used by the content-update pipeline)
#   - Your deploy host (Cloudflare Pages / Netlify / Vercel)
#     dashboard (used by the /api/subscribe function)
# NEVER commit real keys.
# ============================================================

# --- Beehiiv (newsletter opt-in form) ---
# Create at: https://app.beehiiv.com/settings/integrations → API keys
BEEHIIV_API_KEY=
# Your publication ID, looks like: pub_00000000-0000-0000-0000-000000000000
# Find it at: https://app.beehiiv.com/settings/integrations
BEEHIIV_PUBLICATION_ID=

# --- Google Places API (business directory) ---
# Enable "Places API (New)" at https://console.cloud.google.com/apis
# Results are cached in site/src/data/places.json and refreshed weekly,
# so usage stays inside Google's free monthly tier (est. cost: $0/month;
# see site/README.md for the math).
GOOGLE_PLACES_API_KEY=

# --- Eventbrite (optional — extra event listings) ---
# NOTE: Eventbrite retired its public location-search API in 2020. To pull
# events, add Mississauga venue/organizer IDs to site.config.mjs
# (events.eventbriteOrganizers) and set a private token from
# https://www.eventbrite.com/platform/api-keys
EVENTBRITE_API_TOKEN=

# --- Build-time site URL (set by deploy host / CI) ---
# Cloudflare/Netlify/Vercel:  SITE_URL=https://your-domain.com  BASE_PATH=/
# GitHub Pages project site:  SITE_URL=https://<user>.github.io BASE_PATH=/<repo>/
SITE_URL=
BASE_PATH=/
