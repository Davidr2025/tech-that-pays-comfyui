---
import config from "../../site.config.mjs";
const { idSuffix = "hero", formId = config.beehiivFormId } = Astro.props;
// Beehiiv's "Subscribe form" widget has its own email field and submit
// button, so we never render a form of our own — one form, not two.
const fallbackUrl = config.newsletterUrl;
---
<div class="signup-embed-only">
  <div class="signup-embed" id={`signup-embed-${idSuffix}`} data-form-id={formId}></div>
  <p class="signup-embed-fallback">
    Having trouble? <a href={fallbackUrl} target="_blank" rel="noopener">Subscribe directly on our newsletter page →</a>
  </p>
</div>

<script>
  function mountEmbed(container: HTMLElement | null, formId: string) {
    if (!container || container.dataset.mounted) return;
    container.dataset.mounted = "1";
    const script = document.createElement("script");
    script.async = true;
    script.src = "https://subscribe-forms.beehiiv.com/v3/loader.js";
    script.dataset.beehiivForm = formId;
    container.appendChild(script);
  }

  document.querySelectorAll<HTMLElement>(".signup-embed[data-form-id]:not([data-mounted])").forEach((embed) => {
    mountEmbed(embed, embed.dataset.formId!);
  });
</script>
