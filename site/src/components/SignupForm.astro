---
import config from "../../site.config.mjs";
const { compact = false, idSuffix = "hero" } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";
// Serverless endpoint (Cloudflare Pages / Netlify / Vercel). On static-only
// hosts (e.g. GitHub Pages) the script falls back to Beehiiv's inline
// "Subscribe form" embed (loaded lazily, only on failure) instead of a
// redirect — the visitor never leaves the page. See site.config.mjs for
// the form ID and the last-resort text-link URL.
const endpoint = `${base}api/subscribe`;
const fallbackUrl = config.newsletterUrl;
const formId = config.beehiivFormId;
---
<form
  class="signup"
  data-endpoint={endpoint}
  data-form-id={formId}
  data-id-suffix={idSuffix}
  id={`signup-${idSuffix}`}
>
  <input type="email" name="email" required placeholder="you@example.com"
    aria-label="Email address" autocomplete="email" />
  <button type="submit">{compact ? "Subscribe" : "Get the newsletter →"}</button>
  {!compact && <p class="msg" role="status" aria-live="polite"></p>}
</form>

{!compact && <div class="signup-embed" id={`signup-embed-${idSuffix}`} hidden></div>}

{compact && (
  <dialog class="signup-modal" id={`signup-modal-${idSuffix}`}>
    <button class="signup-modal-close" type="button" aria-label="Close" data-signup-modal-close>&times;</button>
    <div class="signup-modal-body">
      <h2>Get the newsletter</h2>
      <div class="signup-embed" id={`signup-embed-${idSuffix}`}></div>
      <p class="signup-modal-fallback">
        Having trouble? <a href={fallbackUrl} target="_blank" rel="noopener">Subscribe directly on our newsletter page →</a>
      </p>
    </div>
  </dialog>
)}

<script>
  function mountEmbed(container: HTMLElement | null, formId: string) {
    if (!container || container.dataset.mounted) return;
    container.dataset.mounted = "1";
    const script = document.createElement("script");
    script.async = true;
    script.src = "https://subscribe-forms.beehiiv.com/v3/loader.js";
    script.dataset.beehiivForm = formId;
    container.appendChild(script);
  }

  document.querySelectorAll<HTMLFormElement>("form.signup:not([data-bound])").forEach((form) => {
    form.dataset.bound = "1";
    const idSuffix = form.dataset.idSuffix!;
    const formId = form.dataset.formId!;
    const embed = document.getElementById(`signup-embed-${idSuffix}`);
    const modal = document.getElementById(`signup-modal-${idSuffix}`) as HTMLDialogElement | null;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = (form.elements.namedItem("email") as HTMLInputElement).value.trim();
      const msg = form.querySelector<HTMLElement>(".msg");
      const btn = form.querySelector<HTMLButtonElement>("button");
      const setMsg = (t: string, ok: boolean) => {
        if (msg) { msg.textContent = t; msg.className = `msg ${ok ? "ok" : "err"}`; }
        else if (btn) { btn.textContent = ok ? "Subscribed ✓" : "Try again"; }
      };
      if (btn) btn.disabled = true;
      try {
        const res = await fetch(form.dataset.endpoint!, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ email })
        });
        const body = await res.json().catch(() => ({}));
        if (res.ok && body.ok) {
          setMsg("You're in! Check your inbox to confirm. 🎉", true);
          form.reset();
        } else {
          throw new Error(body.error || `HTTP ${res.status}`);
        }
      } catch {
        // Static host or API unavailable → Beehiiv's own inline subscribe
        // widget. No page navigation either way.
        if (modal) {
          mountEmbed(embed, formId);
          modal.showModal();
        } else if (embed) {
          form.hidden = true;
          embed.hidden = false;
          mountEmbed(embed, formId);
        } else {
          setMsg("Signup is temporarily unavailable. Please try again shortly.", false);
        }
      } finally {
        if (btn) btn.disabled = false;
      }
    });
  });

  document.querySelectorAll<HTMLDialogElement>(".signup-modal:not([data-bound])").forEach((dialog) => {
    dialog.dataset.bound = "1";
    dialog.querySelector("[data-signup-modal-close]")?.addEventListener("click", () => dialog.close());
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });
  });
</script>
