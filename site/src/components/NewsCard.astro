---
const { item } = Astro.props;
const date = item.publishedAt
  ? new Date(item.publishedAt).toLocaleDateString("en-CA", { month: "short", day: "numeric", timeZone: "America/Toronto" })
  : "";
---
<article class="card">
  <h3>{item.title}</h3>
  {item.summary && <p>{item.summary}</p>}
  <div class="meta">
    <a class="source-badge" href={item.sourceUrl} target="_blank" rel="noopener" title={`Source: ${item.source}`}>{item.source}</a>
    {date && <span>{date}</span>}
  </div>
  <a class="cta-btn secondary news-readmore" href={item.url} target="_blank" rel="noopener">Read full article at {item.source} →</a>
</article>
