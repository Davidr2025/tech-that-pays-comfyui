---
import Base from "../../layouts/Base.astro";
import config from "../../../site.config.mjs";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const spotlights = await getCollection("spotlights");
  return spotlights.map((s) => ({ params: { slug: s.id }, props: { spotlight: s } }));
}

const { spotlight: s } = Astro.props;
const { Content } = await render(s);
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";
const date = s.data.publishDate.toLocaleDateString("en-CA", {
  year: "numeric", month: "long", day: "numeric", timeZone: "America/Toronto"
});
const directoryUrl = s.data.directoryCategory && s.data.directorySlug
  ? `${base}directory/${s.data.directoryCategory}/${s.data.directorySlug}/`
  : null;
const contact = `mailto:david@lsfg.ca?subject=${encodeURIComponent(
  `Get my business spotlighted on ${config.name}`
)}`;
const tierBadge = s.data.tier === "vip" ? "🎥 VIP Partner" : s.data.tier === "paid" ? "Featured Partner" : null;
const videos = s.data.videos || [];
const hasInstagram = videos.some((v) => v.platform === "instagram");
function youtubeId(url: string) {
  try {
    const u = new URL(url);
    if (u.hostname.includes("youtu.be")) return u.pathname.slice(1);
    return u.searchParams.get("v");
  } catch {
    return null;
  }
}
// Instagram's oEmbed lookup expects the canonical /reel/ (singular) or /p/
// permalink form — normalize the "/reels/" (plural, browse-tab) URL shape
// some share sheets produce, or the widget silently falls back to a bare
// "View this post" link instead of the actual embedded post.
function instagramPermalink(url: string) {
  try {
    const u = new URL(url);
    u.pathname = u.pathname.replace(/^\/reels\//, "/reel/");
    return u.toString();
  } catch {
    return url;
  }
}
---
<Base title={`${s.data.businessName} · Business Spotlight`} description={s.data.description} current="spotlight">
  <section class="section container guide-detail">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href={`${base}spotlight/`}>Business Spotlight</a>
      <span>›</span>
      <span>{s.data.businessName}</span>
    </nav>

    <div class="biz-detail-layout">
      {s.data.photo && <img class="biz-detail-hero" src={s.data.photo} alt={s.data.businessName} />}
      <div class="biz-detail-body">
        {tierBadge && <span class="tag">{tierBadge}</span>}
        <h1>{s.data.title}</h1>
        <p class="guide-meta">{s.data.category} · Published {date}</p>

        <div class="biz-detail-actions">
          {directoryUrl && <a class="cta-btn" href={directoryUrl}>View full listing →</a>}
          {s.data.website && (
            <a class="cta-btn secondary" href={s.data.website} target="_blank" rel="noopener">Visit website →</a>
          )}
        </div>
      </div>
    </div>

    {videos.length > 0 && (
      <div class="spotlight-videos">
        <h2>Watch</h2>
        <div class="spotlight-video-grid">
          {videos.map((v) => (
            v.platform === "youtube" ? (
              <div class="video-embed video-embed-youtube">
                <iframe
                  src={`https://www.youtube.com/embed/${youtubeId(v.url)}`}
                  title={v.caption || s.data.businessName}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
            ) : (
              <blockquote
                class="instagram-media"
                data-instgrm-permalink={instagramPermalink(v.url)}
                data-instgrm-captioned
                data-instgrm-version="14"
              >
                <a href={instagramPermalink(v.url)} target="_blank" rel="noopener">View this post on Instagram</a>
              </blockquote>
            )
          ))}
        </div>
      </div>
    )}

    <div class="prose">
      <Content />
    </div>

    <div class="biz-detail-cta">
      <h3>Want your business featured next?</h3>
      <p>Basic spotlights are free, we just need a good story to tell. Featured Partner spotlights add homepage placement and a newsletter mention; VIP spotlights also feature a video.</p>
      <a class="cta-btn" href={contact}>Get spotlighted →</a>
    </div>
  </section>
  {hasInstagram && <script async src="https://www.instagram.com/embed.js" is:inline></script>}
</Base>
