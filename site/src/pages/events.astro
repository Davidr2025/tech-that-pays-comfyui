---
import Base from "../layouts/Base.astro";
import EventCard from "../components/EventCard.astro";
import AdSlot from "../components/AdSlot.astro";
import config from "../../site.config.mjs";
import events from "../data/events.json";
import recommendations from "../data/recommendations.json";

const mid = Math.ceil(events.items.length / 2);
const firstHalf = events.items.slice(0, mid);
const secondHalf = events.items.slice(mid);
---
<Base title="Things to Do" description={`What's on in ${config.city} over the next ${events.windowDays} days: concerts, festivals, family events and more.`} current="events">
  <section class="section container">
    <div class="section-head">
      <h2>Things to Do in {config.city}</h2>
      <span class="sub">Next {events.windowDays} days · from the {config.events.city.name}</span>
    </div>
    {events.items.length ? (
      <>
        <div class="grid">{firstHalf.map((item) => <EventCard item={item} />)}</div>
        {secondHalf.length > 0 && (
          <>
            <AdSlot id="events-mid" variant="banner" />
            <div class="grid">{secondHalf.map((item) => <EventCard item={item} />)}</div>
          </>
        )}
      </>
    ) : (
      <p class="empty">
        Event listings refresh automatically every 6 hours.
        Meanwhile, browse the <a href={config.events.city.homepage} target="_blank" rel="noopener">Visit Mississauga events calendar</a>.
      </p>
    )}
  </section>

  {recommendations.items.length > 0 && (
    <section class="section container" id="free-things">
      <div class="section-head">
        <h2>Free Things to Do</h2>
        <span class="sub">Recommended by the Mississauga Insider team, any time of year</span>
      </div>
      <div class="grid">{recommendations.items.map((item) => <EventCard item={item} />)}</div>
    </section>
  )}
</Base>
