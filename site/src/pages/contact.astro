---
import Base from "../layouts/Base.astro";
import config from "../../site.config.mjs";
---
<Base title="Contact Us" description={`Get in touch with ${config.name}: questions, story tips, or advertising.`} current="contact">
  <section class="section container" style="max-width:760px">
    <h2>Contact Us</h2>
    <p>
      Questions, story tips, or interested in advertising? Send us a message below and we'll get
      back to you.
    </p>
    <div class="contact-form-embed">
      <iframe
        src="https://site.getlimitlesscustomers.com/widget/form/sCAbuNqcEsfYxpUnPQZq"
        style="width:100%;height:100%;border:none;border-radius:4px"
        id="inline-sCAbuNqcEsfYxpUnPQZq"
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="Mississauga Insider Contact Us"
        data-height="undefined"
        data-layout-iframe-id="inline-sCAbuNqcEsfYxpUnPQZq"
        data-form-id="sCAbuNqcEsfYxpUnPQZq"
        title="Mississauga Insider Contact Us"
      ></iframe>
    </div>
  </section>
  <script src="https://site.getlimitlesscustomers.com/js/form_embed.js"></script>
</Base>
