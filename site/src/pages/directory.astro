---
import Base from "../layouts/Base.astro";
import config from "../../site.config.mjs";
import places from "../data/places.json";
import featuredPlaces from "../data/featured-places.json";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";
const featuredIds = new Set(featuredPlaces.map((f) => f.id));

// Categories fetched via subcategory queries (e.g. Trades & Home Services)
// carry a `subcategory` on each business — group those under sub-headings
// so a resident scanning "Trades" sees Plumbers, Electricians, etc. rather
// than one undifferentiated grid. Categories without subcategory data
// render exactly as before (one group, no sub-heading).
//
// Featured businesses (paid upgrade, see src/data/featured-places.json)
// sort to the top of their group ahead of the normal rating sort, and
// carry a `featured` flag through to rendering for the badge/highlight.
function sortFeaturedFirst(businesses) {
  return businesses
    .map((b) => ({ ...b, featured: featuredIds.has(b.id) }))
    .sort((a, b) => (b.featured ? 1 : 0) - (a.featured ? 1 : 0));
}

const cats = places.categories
  .filter((c) => c.businesses.length > 0)
  .map((cat) => {
    if (!cat.businesses.some((b) => b.subcategory)) {
      return { ...cat, groups: [{ label: null, businesses: sortFeaturedFirst(cat.businesses) }] };
    }
    const order = [];
    const byLabel = new Map();
    for (const b of cat.businesses) {
      const key = b.subcategory || "Other";
      if (!byLabel.has(key)) { byLabel.set(key, []); order.push(key); }
      byLabel.get(key).push(b);
    }
    return { ...cat, groups: order.map((label) => ({ label, businesses: sortFeaturedFirst(byLabel.get(label)) })) };
  });
const fetched = places.fetchedAt
  ? new Date(places.fetchedAt).toLocaleDateString("en-CA", { dateStyle: "medium", timeZone: "America/Toronto" })
  : null;
---
<Base title="Business Directory" description={`Local business directory for ${config.city}: restaurants, trades, real estate, health and more, with ratings, hours and photos.`} current="directory">
  <section class="section container">
    <div class="section-head">
      <h2>{config.city} Business Directory</h2>
      <span class="sub">{fetched ? `Refreshed monthly · last updated ${fetched}` : "Refreshed monthly"}</span>
      <a class="more" href={`${base}advertise/`}>List your business →</a>
    </div>

    {places.sampleData && (
      <p class="notice">
        ⚠️ Showing sample listings. Live ratings, hours and photos load automatically from the
        Google Places API once <code>GOOGLE_PLACES_API_KEY</code> is configured (see <code>.env.example</code>).
      </p>
    )}

    <div class="dir-search-wrap">
      <input
        type="search"
        id="dir-search"
        class="dir-search"
        placeholder="Search businesses, categories, or streets…"
        aria-label="Search the business directory"
      />
    </div>

    <nav class="dir-nav" aria-label="Categories">
      {cats.map((c) => <a href={`#${c.slug}`}>{c.label}</a>)}
    </nav>

    <p id="dir-no-results" class="empty" hidden>No businesses match your search. Try a different term.</p>

    {cats.map((cat) => (
      <section id={cat.slug} class="dir-cat" style="margin-bottom:2.5rem">
        <h3 style="font-size:1.2rem;margin-bottom:.9rem">{cat.label}</h3>
        {cat.groups.map((g) => (
          <div class="dir-group" style="margin-bottom:1.75rem">
            {g.label && <h4 style="font-size:.95rem;font-weight:700;color:var(--primary);margin:0 0 .6rem">{g.label}</h4>}
            <div class="grid">
              {g.businesses.map((b) => (
                <article
                  class={`card biz-card${b.featured ? " biz-card-featured" : ""}`}
                  data-search={`${b.name} ${cat.label} ${g.label || ""} ${b.address || ""}`.toLowerCase()}
                >
                  {b.featured && <span class="tag featured-tag">★ Featured</span>}
                  {b.photo && <img class="photo" src={b.photo} alt={b.name} loading="lazy" />}
                  <h3><a href={`${base}directory/${cat.slug}/${b.slug}/`}>{b.name}</a></h3>
                  {b.rating != null && (
                    <div class="rating">★ {b.rating.toFixed(1)} <span class="cnt">({b.reviews?.toLocaleString()} reviews)</span></div>
                  )}
                  <p>{b.address}</p>
                  <div class="meta">
                    <a class="readmore" href={`${base}directory/${cat.slug}/${b.slug}/`}>View details →</a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))}
      </section>
    ))}

    <p style="font-size:.8rem;color:var(--muted)">{places.attribution}</p>
  </section>

  <script>
    const input = document.getElementById("dir-search");
    const cards = Array.from(document.querySelectorAll(".biz-card"));
    const groups = Array.from(document.querySelectorAll(".dir-group"));
    const cats = Array.from(document.querySelectorAll(".dir-cat"));
    const noResults = document.getElementById("dir-no-results");

    input?.addEventListener("input", () => {
      const q = input.value.trim().toLowerCase();
      let visibleTotal = 0;

      for (const card of cards) {
        const match = !q || (card.getAttribute("data-search") || "").includes(q);
        card.hidden = !match;
        if (match) visibleTotal++;
      }
      for (const group of groups) {
        const anyVisible = group.querySelector(".biz-card:not([hidden])");
        group.hidden = !anyVisible;
      }
      for (const cat of cats) {
        const anyVisible = cat.querySelector(".biz-card:not([hidden])");
        cat.hidden = !anyVisible;
      }
      if (noResults) noResults.hidden = visibleTotal > 0;
    });
  </script>
</Base>
